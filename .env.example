# Copy this file to .env for local/VPS runs (or set these as real
# environment variables on Render / Railway / Docker / etc.)

# REQUIRED
TOKEN=123456:your-bot-token-from-botfather
OWNER_ID=123456789

# RECOMMENDED
OWNER_USERNAME=your_username
DATABASE_URL=postgresql://user:password@host:5432/dbname
BOT_USERNAME=MissRoseV1Pro_Bot
UPDATE_CHANNEL=BotBaseOfficial

# OPTIONAL
SUDO_USERS=
SUPPORT_USERS=
WHITELIST_USERS=
DONATION_LINK=
LOAD=
NO_LOAD=translation
DEL_CMDS=False
STRICT_GBAN=False
WORKERS=4
ALLOW_EXCL=False

# Leave WEBHOOK unset / False on Render's free tier - long polling +
# keep_alive.py is far more reliable there and is what this repo is
# configured for by default.
WEBHOOK=False

# PORT is provided automatically by Render - no need to set it yourself.
PORT=5000
